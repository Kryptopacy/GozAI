        {
          "invocation_id": "inv_1",
          "user_content": {
            "parts": [{ "text": "Can you tell me about timolol eye drops?" }]
          },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "Timolol is a beta-blocker eye drop commonly used to treat glaucoma by reducing eye pressure. It is usually applied once or twice daily. Do not use if you have asthma or certain heart conditions without your doctor's approval. Always follow your doctor's specific instructions." }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "get_medication_info", "args": { "medication_name": "timolol" } }
