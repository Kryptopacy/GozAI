  "eval_cases": [

    {
      "eval_id": "optometry_dry_eyes",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": {
            "parts": [{ "text": "My eyes feel really dry lately, what should I do?" }]
          },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "Dry eye disease is common, especially with screen use. You can try the 20-20-20 rule: every 20 minutes, look 20 feet away for 20 seconds. Use preservative-free artificial tears and stay hydrated. Please consult your optometrist if symptoms persist." }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "search_optometry_guidelines", "args": { "query": "dry eyes" } }
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "gozai_agent",
        "user_id": "eval_user_001",
        "state": {}
      }
    },

    {
