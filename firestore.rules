rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Patient Data & Medical Memory
    // Allows patients to read/write their own data and caregivers to read it.
    match /patients/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'caregiver');
    }

    // 2. SOS Alerts
    // Patients create alerts; Caregivers resolve them.
    match /sos_alerts/{userId} {
      allow read, write: if request.auth != null;
    }

    // 3. Clinical RAG Data
    // Publicly readable for the agent (verified medical info), but only admins can write.
    match /gozai_rag_data/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 4. Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
