{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/build/web/$1"
    },
    {
      "source": "/",
      "destination": "/build/web/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    }
  ]
}
